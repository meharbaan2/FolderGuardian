<Window x:Class="FolderGuardian.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FolderGuardian"
        Width="1120"
        Height="760"
        MinWidth="860"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#DCEEFF"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Closing="Window_Closing">
    <Window.Resources>
        <LinearGradientBrush x:Key="PageBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#EAF6FF" Offset="0" />
            <GradientStop Color="#D9F0FF" Offset="0.45" />
            <GradientStop Color="#F7FBFF" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ShellBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F3FBFF" Offset="0" />
            <GradientStop Color="#EAF7FF" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1D7DFF" Offset="0" />
            <GradientStop Color="#35C6FF" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SecondaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F4FAFF" Offset="0" />
            <GradientStop Color="#E5F3FF" Offset="1" />
        </LinearGradientBrush>

        <SolidColorBrush x:Key="CardBrush" Color="#F6FBFF" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#9CCBEA" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#173456" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#5B7697" />
        <SolidColorBrush x:Key="FieldBrush" Color="#F8FCFF" />
        <SolidColorBrush x:Key="FieldBorderBrush" Color="#A7D1F1" />
        <SolidColorBrush x:Key="AccentBrush" Color="#43C8FF" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#D9F5FF" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.12" Color="#5AA5E0" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold" />
            <Setter Property="FontSize" Value="23" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="FieldTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource FieldBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        </Style>

        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
            <Setter Property="FontSize" Value="14.5" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1875F2" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontFamily" Value="Segoe UI Semibold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.12" Color="#4BAAF2" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,0" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SecondaryButtonBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="#A7D1F1" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Ellipse Width="340"
                 Height="340"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-80,-90,0,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#CC7FDBFF" Offset="0" />
                    <GradientStop Color="#007FDBFF" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Ellipse Width="420"
                 Height="420"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-120,-140">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#AA9CEBFF" Offset="0" />
                    <GradientStop Color="#009CEBFF" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      CanContentScroll="False"
                      PanningMode="Both"
                      Margin="0">
            <Border Margin="22"
                    MinWidth="1000"
                    MinHeight="700"
                    Padding="28"
                    Background="{StaticResource ShellBrush}"
                    BorderBrush="#B6EBFFFF"
                    BorderThickness="1.2"
                    CornerRadius="32">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.22" Color="#5C9FE0" />
                </Border.Effect>

                <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <Border Padding="10,5"
                                Background="#E6F8FFFF"
                                BorderBrush="#A9DFFF"
                                BorderThickness="1"
                                CornerRadius="13"
                                HorizontalAlignment="Left">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       FontFamily="Segoe UI Semibold"
                                       Foreground="#2678B7"
                                       Text="LOCAL VAULT + WATCHTOWER" />
                        </Border>

                        <TextBlock Margin="0,16,0,0"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="38"
                                   FontWeight="SemiBold"
                                   Text="FolderGuardian" />

                        <TextBlock Margin="0,10,0,0"
                                   FontSize="15"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Text="A brighter control surface for secure folder operations, legacy recovery, and live filesystem telemetry." />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#F4FBFF"
                            BorderBrush="#93CFF6"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="16,12"
                            VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="System Status" />
                            <TextBlock x:Name="StatusText"
                                       Margin="0,5,0,0"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="Ready" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.1*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Target Directory" />
                                <TextBlock Margin="0,7,0,18"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Point FolderGuardian at the folder you want to shield, recover, or keep under watch." />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox x:Name="FolderPathBox"
                                             Style="{StaticResource FieldTextBoxStyle}" />

                                    <Button x:Name="BrowseBtn"
                                            Grid.Column="1"
                                            Margin="12,0,0,0"
                                            Content="Browse"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="BrowseBtn_Click" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Operations Console" />
                                <TextBlock Margin="0,7,0,18"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Run encryption or recovery in the background, then switch monitoring on when you want live signals." />

                                <UniformGrid Columns="3" Margin="0,0,0,0">
                                    <Button x:Name="EncryptBtn"
                                            Margin="0,0,10,0"
                                            Content="Encrypt"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Click="EncryptBtn_Click" />
                                    <Button x:Name="DecryptBtn"
                                            Margin="0,0,10,0"
                                            Content="Decrypt"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="DecryptBtn_Click" />
                                    <Button x:Name="MonitorBtn"
                                            Content="Start Watch"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="MonitorBtn_Click" />
                                </UniformGrid>

                                <ProgressBar x:Name="OperationProgressBar"
                                             Margin="0,18,0,0"
                                             Height="9"
                                             Foreground="{StaticResource AccentBrush}"
                                             Background="#D4EFFF"
                                             BorderThickness="0"
                                             Maximum="1"
                                             Value="0"
                                             IsIndeterminate="False" />

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock x:Name="ProgressText"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontFamily="Segoe UI Semibold"
                                               Text="Idle" />

                                    <TextBlock x:Name="EtaText"
                                               Grid.Column="1"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="ETA --" />
                                </Grid>

                                <TextBlock x:Name="CurrentItemText"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="Waiting for an operation."
                                           TextTrimming="CharacterEllipsis" />

                                <Border Margin="0,16,0,0"
                                        Padding="14,10"
                                        Background="#EAF8FF"
                                        BorderBrush="#B0DFFF"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                    <TextBlock x:Name="RunSummaryText"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="Pick a folder to begin." />
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource SectionCardStyle}" Margin="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                                               Text="Activity Stream" />
                                    <Border Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            Padding="9,5"
                                            Background="#EAF8FF"
                                            BorderBrush="#A6D8F8"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <TextBlock Foreground="#2A80BF"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   FontFamily="Segoe UI Semibold"
                                                   Text="LIVE" />
                                    </Border>
                                </Grid>

                                <TextBox x:Name="LogBox"
                                         Grid.Row="1"
                                         Margin="0,18,0,16"
                                         Padding="14"
                                         FontFamily="Cascadia Mono"
                                         FontSize="13"
                                         Foreground="#183D63"
                                         Background="#F5FBFF"
                                         BorderBrush="#ABD7F6"
                                         BorderThickness="1"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Disabled"
                                         AcceptsReturn="True"
                                         IsReadOnly="True" />

                                <Button Grid.Row="2"
                                        HorizontalAlignment="Right"
                                        Content="Clear Log"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="ClearLog_Click" />
                            </Grid>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Column="2">
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Telemetry" />

                                <Border Margin="0,16,0,0"
                                        Padding="14"
                                        Background="#F4FBFF"
                                        BorderBrush="#B3DFFF"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                    <StackPanel>
                                        <TextBlock FontSize="11"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="Selected Folder" />
                                        <TextBlock x:Name="SelectedFolderText"
                                                   Margin="0,6,0,0"
                                                   Style="{StaticResource ValueTextStyle}"
                                                   Text="No folder selected" />
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,12,0,0"
                                        Padding="14"
                                        Background="#F4FBFF"
                                        BorderBrush="#B3DFFF"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                    <StackPanel>
                                        <TextBlock FontSize="11"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="Key Storage" />
                                        <TextBlock x:Name="KeyPathText"
                                                   Margin="0,6,0,0"
                                                   Style="{StaticResource ValueTextStyle}"
                                                   Text="Loading key details..." />
                                    </StackPanel>
                                </Border>

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Padding="14"
                                            Background="#F4FBFF"
                                            BorderBrush="#B3DFFF"
                                            BorderThickness="1"
                                            CornerRadius="16">
                                        <StackPanel>
                                            <TextBlock FontSize="11"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Text="Monitor" />
                                            <TextBlock x:Name="MonitorStateText"
                                                       Margin="0,6,0,0"
                                                       Style="{StaticResource ValueTextStyle}"
                                                       Text="Stopped" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Padding="14"
                                            Background="#F4FBFF"
                                            BorderBrush="#B3DFFF"
                                            BorderThickness="1"
                                            CornerRadius="16">
                                        <StackPanel>
                                            <TextBlock FontSize="11"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Text="Entries" />
                                            <TextBlock x:Name="ActivityCountText"
                                                       Margin="0,6,0,0"
                                                       Style="{StaticResource ValueTextStyle}"
                                                       Text="0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Quick Access" />

                                <Button Margin="0,18,0,12"
                                        HorizontalAlignment="Left"
                                        MinWidth="168"
                                        Content="Open Security Log"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="OpenLogBtn_Click" />

                                <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                           Text="Jump straight into the on-disk event log the moment you want raw traces." />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}" Margin="0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Compatibility" />

                                <Border Margin="0,16,0,0"
                                        Padding="12"
                                        Background="#EAF8FF"
                                        BorderBrush="#A8D8F7"
                                        BorderThickness="1"
                                        CornerRadius="15">
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="New encryptions use per-file randomness and integrity checks so modified payloads are rejected instead of decrypted silently." />
                                </Border>

                                <Border Margin="0,12,0,0"
                                        Padding="12"
                                        Background="#EAF8FF"
                                        BorderBrush="#A8D8F7"
                                        BorderThickness="1"
                                        CornerRadius="15">
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="Older `.enc` files still fall back to the previous recovery path, and the legacy DPAPI key stays preserved for that reason." />
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
